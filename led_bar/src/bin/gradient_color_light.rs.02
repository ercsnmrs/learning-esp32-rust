#![no_std]
#![no_main]
#![deny(
    clippy::mem_forget,
    reason = "mem::forget is generally not safe to do with esp_hal types, especially those \
    holding buffers for the duration of a data transfer."
)]
#![deny(clippy::large_stack_frames)]

use esp_hal::{
    clock::CpuClock,
    gpio::DriveMode,
    main,
    time::{Duration, Instant, Rate},
};

use esp_hal::ledc::{
    channel::{self, ChannelHW, ChannelIFace},
    timer::{self, TimerIFace},
    LSGlobalClkSource, Ledc, LowSpeed,
};

use esp_println as _;

use esp_backtrace as _;


// This creates a default app-descriptor required by the esp-idf bootloader.
// For more information see: <https://docs.espressif.com/projects/esp-idf/en/stable/esp32/api-reference/system/app_image_format.html#application-description>
esp_bootloader_esp_idf::esp_app_desc!();

#[allow(
    clippy::large_stack_frames,
    reason = "it's not unusual to allocate larger buffers etc. in main"
)]
#[main]
fn main() -> ! {
    // generator version: 1.3.0
    // generator parameters: --chip esp32s3 -o unstable-hal -o defmt -o esp-backtrace


    let config = esp_hal::Config::default().with_cpu_clock(CpuClock::max());
    let peripherals = esp_hal::init(config);

    // mypwm = myPWM(21, 47, 38, 39, 40, 41, 42, 2)
    let mut ledc = Ledc::new(peripherals.LEDC);
    ledc.set_global_slow_clock(LSGlobalClkSource::APBClk);

    let mut lstimer0 = ledc.timer::<LowSpeed>(timer::Number::Timer0);
    lstimer0
        .configure(timer::config::Config {
            duty: timer::config::Duty::Duty10Bit,
            clock_source: timer::LSClockSource::APBClk,
            frequency: Rate::from_khz(5),
        })
        .unwrap();

    let chan_cfg = channel::config::Config {
        timer: &lstimer0,
        duty_pct: 0,
        drive_mode: DriveMode::PushPull,
    };

    let mut ch0 = ledc.channel(channel::Number::Channel0, peripherals.GPIO21);
    let mut ch1 = ledc.channel(channel::Number::Channel1, peripherals.GPIO47);
    let mut ch2 = ledc.channel(channel::Number::Channel2, peripherals.GPIO38);
    let mut ch3 = ledc.channel(channel::Number::Channel3, peripherals.GPIO39);
    let mut ch4 = ledc.channel(channel::Number::Channel4, peripherals.GPIO40);
    let mut ch5 = ledc.channel(channel::Number::Channel5, peripherals.GPIO41);
    let mut ch6 = ledc.channel(channel::Number::Channel6, peripherals.GPIO42);
    let mut ch7 = ledc.channel(channel::Number::Channel7, peripherals.GPIO2);

    ch0.configure(chan_cfg).unwrap();
    ch1.configure(chan_cfg).unwrap();
    ch2.configure(chan_cfg).unwrap();
    ch3.configure(chan_cfg).unwrap();
    ch4.configure(chan_cfg).unwrap();
    ch5.configure(chan_cfg).unwrap();
    ch6.configure(chan_cfg).unwrap();
    ch7.configure(chan_cfg).unwrap();

    let channels = [ch0, ch1, ch2, ch3, ch4, ch5, ch6, ch7];

    // chns = [0,1,2,3,4,5,6,7]
    let chns: [usize; 8] = [0, 1, 2, 3, 4, 5, 6, 7];
    // dutys = [0,0,0,0,0,0,0,0, 1023,512,256,128,64,32,16,8, 0,0,0,0,0,0,0,0]
    let dutys: [u32; 24] = [
        0, 0, 0, 0, 0, 0, 0, 0, 1023, 512, 256, 128, 64, 32, 16, 8, 0, 0, 0, 0, 0, 0, 0, 0,
    ];
    // delayTimes = 50
    let delay_times: u64 = 50;

    loop {
        for i in 0..16 {
            for j in 0..8 {
                channels[chns[j]].set_duty_hw(dutys[i + j]);
            }
            let start = Instant::now();
            while start.elapsed() < Duration::from_millis(delay_times) {}
        }

        for i in 0..16 {
            for j in 0..8 {
                channels[chns[7 - j]].set_duty_hw(dutys[i + j]);
            }
            let start = Instant::now();
            while start.elapsed() < Duration::from_millis(delay_times) {}
        }
    }
}